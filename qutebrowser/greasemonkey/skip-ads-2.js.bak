// ==UserScript==
// @name         Youtube Ad Skip 2
// @version      0.0.4
// @author       Adcott
// @match        *://*.youtube.com/*
// ==/UserScript==

document.addEventListener('load', () => {
        try { document.querySelector('.ad-showing video').currentTime = 100 } catch {}
        try { document.querySelector('.ytp-ad-skip-button').click() } catch {}
}, true);
